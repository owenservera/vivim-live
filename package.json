{
  "name": "vivim-live",
  "version": "1.0.0",
  "private": true,
  "description": "VIVIM — Sovereign, Portable, Personal AI Memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/owenservera/vivim-live.git"
  },
  "bugs": {
    "url": "https://github.com/owenservera/vivim-live/issues"
  },
  "homepage": "https://github.com/owenservera/vivim-live#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:frontend": "bun run --filter vivim-live dev",
    "dev:backend": "bun run --filter vivim-server dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:frontend": "bun run --filter vivim-live build",
    "build:backend": "bun run --filter vivim-server build",
    "start": "bun run start:frontend",
    "start:frontend": "bun run --filter vivim-live start",
    "start:backend": "bun run --filter vivim-server start",
    "lint": "bun run lint:frontend && bun run lint:backend",
    "lint:frontend": "bun run --filter vivim-live lint",
    "lint:backend": "bun run --filter vivim-server lint",
    "test": "bun run test:frontend && bun run test:backend",
    "test:frontend": "bun run --filter vivim-live test",
    "test:backend": "bun run --filter vivim-server test",
    "db:migrate": "bun run --filter vivim-server db:migrate",
    "db:generate": "bun run --filter vivim-server db:generate",
    "db:studio": "bun run --filter vivim-server db:studio",
    "db:seed": "bun run --filter vivim-server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "next": "^15.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}

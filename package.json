{
  "name": "vivim-live",
  "version": "1.0.0",
  "description": "VIVIM Live - Sovereign AI Interface with Documentation",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:docs\"",
    "build": "node build.js",
    "build:web": "cd github-frontend && bun run build",
    "build:docs": "cd docs && bun run build",
    "install:all": "bun install && cd github-frontend && bun install && cd ../docs && bun install",
    "lint": "echo 'No root-level linting configured'",
    "lint:docs": "cd docs && bun run lint",
    "lint:frontend": "cd github-frontend && bun run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run typecheck:docs && bun run typecheck:frontend",
    "typecheck:docs": "cd docs && bun run typecheck",
    "typecheck:frontend": "cd github-frontend && bun run build",
    "test": "echo 'No tests configured yet'",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "semantic-release": "^24.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^9.0.0",
    "@semantic-release/npm": "^12.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/owenservera/vivim-live.git"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}

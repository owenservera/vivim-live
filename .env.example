# ============================================================================
# VIVIM - VirtualUser-Only Implementation
# ============================================================================
# Minimal environment configuration for fingerprint-based anonymous chat
# Copy to .env.local and configure as needed
# ============================================================================

# ============================================================================
# DATABASE (Required - PostgreSQL)
# ============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vivim_dev"
DATABASE_SSL_REQUIRED=false

# ============================================================================
# REDIS (Optional - for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
TRUST_PROXY=false

# ============================================================================
# SECURITY (Required - change in production)
# ============================================================================
SESSION_SECRET=your-session-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars

# ============================================================================
# CORS (Optional - defaults to localhost in dev)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================================================
# GLOBAL RATE LIMITER - AI API Request Funnel
# ============================================================================
# Enforces 2-second interval between all AI API requests
GLOBAL_RATE_LIMIT_INTERVAL_MS=2000
GLOBAL_RATE_LIMIT_MAX_QUEUE=1000
GLOBAL_RATE_LIMIT_TIMEOUT_MS=60000
GLOBAL_RATE_LIMIT_ENABLE_PRIORITY=false

# ============================================================================
# AI PROVIDER - Z.AI (Required for chat)
# ============================================================================
ZAI_API_KEY=your-zai-api-key
ZAI_MODEL=glm-4.7
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_EMBEDDING_DIMENSIONS=1536

# ============================================================================
# CONTEXT ENGINE (Optional - enabled by default)
# ============================================================================
USE_DYNAMIC_CONTEXT=true
DYNAMIC_CONTEXT_LOG_LEVEL=info

# ============================================================================
# LIBRARIAN WORKER (Optional - autonomous learning)
# ============================================================================
LIBRARIAN_ENABLED=true
LIBRARIAN_BATCH_SIZE=20
LIBRARIAN_COOLDOWN_MINUTES=30
ENABLE_IDLE_DETECTION=true
CONVERSATION_IDLE_TIMEOUT_MINUTES=5

# ============================================================================
# LOGGING (Optional)
# ============================================================================
LOG_LEVEL=info
DEBUG=false

# ============================================================================
# OPTIONAL API DOCS
# ============================================================================
ENABLE_SWAGGER=true

# ============================================================================
# TOKEN ESTIMATION (Optional)
# ============================================================================
TOKEN_ESTIMATOR_TYPE=tiktoken

# ============================================================================
# OPTIONAL - Alternative AI Providers (Fallback)
# ============================================================================
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_AI_MODEL=gemini-1.5-flash

# XAI_API_KEY=
# XAI_MODEL=grok-beta

# ============================================================================
# OPTIONAL - Error Tracking (Sentry)
# ============================================================================
# SENTRY_DSN=
# SENTRY_RELEASE=
# SENTRY_ENVIRONMENT=production

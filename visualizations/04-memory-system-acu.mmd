## ACU Database Schema

```sql
-- Key ACU fields (from schema.prisma)
model AtomicChatUnit {
    id              String    @id @default(uuid())
    content         String
    type            String    -- 'thought', 'response', 'code', 'fact', etc.
    category        String    -- 'episodic', 'semantic', 'procedural', etc.
    state           String    @default("ACTIVE") -- 'ACTIVE', 'ARCHIVED', 'DELETED'
    importance      Float     @default(0.5)
    authorDid       String    -- Decentralized ID of author
    embedding       Float[]   @db.Vector(1536) -- pgvector
    
    conversationId  String
    messageId       String
    
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    
    @@index([userId])
    @@index([type, category])
    @@index([state])
    @@index([importance(sort: Desc)])
    @@index([embedding])
}
```


# Context Engine Deep Dive Visualization

## Context Pipeline Class Diagram

```mermaid
classDiagram
    class ParallelContextPipeline {
        -prisma: PrismaClient
        -embeddingService: IEmbeddingService
        -tokenEstimator: ITokenEstimator
        -llmService: ILLMService
        -cache: ContextCache
        -eventBus: ContextEventBus
        -maxConcurrency: number
        +assembleParallel(params): Promise~AssembledContext + Metrics~
        +assembleStreaming(params): AsyncGenerator~StreamingContextChunk~
        -timedStage(name, fn): PipelineStageResult~T~
        -fetchSettings(userId): any
        -embedMessage(message): number[]
        -fetchConversation(conversationId): any
        -detectContext(userId, message, embedding, convId): DetectedContext
        -fetchOrCompileBundle(userId, bundleType, refId): CompiledBundle | null
        -jitRetrieve(userId, message, embedding, context): JITKnowledge
        -compilePromptFromBundles(bundles, jit, maxTokens): string
        -formatJITContent(jit): string
    }

    class ConcurrencyLimiter {
        -running: number
        -queue: Array~{fn, resolve, reject}~
        -maxConcurrent: number
        +run(fn): Promise~T~
        -execute(fn): Promise~T~
        -processQueue(): void
        +pendingCount: number
        +activeCount: number
    }

    class ContextCache {
        -settingsCache: Map~string, any~
        -embeddingsCache: Map~string, number[]~
        -bundleCache: Map~string, CompiledBundle~
        -graphCache: Map~string, ContextGraph~
        +getSettings(userId): any
        +setSettings(userId, settings): void
        +getCachedEmbedding(message): number[] | null
        +setCachedEmbedding(message, embedding): void
        +getBundle(userId, type, refId): CompiledBundle | null
        +setBundle(userId, type, bundle, refId): void
        +getGraph(userId): ContextGraph | null
    }

    class ContextEventBus {
        -listeners: Map~string, Array~Function~~
        +on(event, handler): void
        +off(event, handler): void
        +emit(event, ...args): void
    }

    ParallelContextPipeline --> ContextCache
    ParallelContextPipeline --> ContextEventBus
    ParallelContextPipeline --> ConcurrencyLimiter
```


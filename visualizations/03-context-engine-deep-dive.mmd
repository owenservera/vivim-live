## Budget Algorithm

```mermaid
flowchart TB
    subgraph "Input"
        settings["settings.maxContextTokens (default: 12000)"]
        userMsg["userMessage"]
    end

    calc["userTokens = tokenEstimator.estimate(userMessage)"]
    avail["availableTokens = totalBudget - userTokens"]

    subgraph "Bundle Sorting"
        priority["priorityOrder = {<br/>identity_core: 100,<br/>global_prefs: 90,<br/>conversation: 80,<br/>topic: 70,<br/>entity: 60,<br/>composite: 50<br/>}"]
        sort["Sort bundles by priority (descending)"]
    end

    subgraph "Budget Allocation"
        loop["For each bundle:"]
        check["tokensUsed + bundle.tokenCount > maxTokens?"]
        fit["Add full bundle"]
        truncate["Truncate to fit remaining"]
        break["Break if no space left"]
    end

    subgraph "JIT Addition"
        jit_check["tokensUsed < maxTokens * 0.9?"]
        jit_format["Format JIT content"]
        jit_tokens["Estimate JIT tokens"]
        jit_fit["tokensUsed + jitTokens <= maxTokens?"]
        jit_add["Add JIT content"]
    end

    output["systemPrompt: string"]

    settings --> calc
    userMsg --> calc
    calc --> avail
    avail --> priority
    priority --> sort
    sort --> loop
    loop --> check
    check -->|No| fit
    check -->|Yes| truncate
    truncate --> break
    fit --> loop
    loop --> jit_check
    jit_check -->|Yes| jit_format
    jit_check -->|No| output
    jit_format --> jit_tokens
    jit_tokens --> jit_fit
    jit_fit -->|Yes| jit_add
    jit_fit -->|No| output
    jit_add --> output

    style calc fill:#1a1a2e,stroke:#4a4a6a
    style loop fill:#2d2d44,stroke:#5a5a7a
    style output fill:#16213e,stroke:#0f3460
```

## Key Interfaces

```typescript
interface AssemblyParams {
  userId: string;
  conversationId?: string;
  userMessage: string;
}

interface AssembledContext {
  systemPrompt: string;
  budget: TokenBudget;
  bundlesUsed: string[];
  metadata: {
    assemblyTimeMs: number;
    detectedTopics: number;
    detectedEntities: number;
    cacheHitRate: number;
  };
  metrics: PipelineMetrics;
}

interface PipelineMetrics {
  totalDurationMs: number;
  stages: Record<string, { durationMs: number; source: 'cache' | 'computed'; error?: string }>;
  parallelFactor: number;
  cacheHitRate: number;
  tokensBudgeted: number;
  tokensUsed: number;
}

interface StreamingContextChunk {
  layer: string;
  content: string;
  tokenCount: number;
  priority: number;
  isFinal: boolean;
}
```
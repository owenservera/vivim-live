# VIVIM Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# REQUIRED: Backend API
# =============================================================================

# Backend service URL (required for chat functionality)
# The backend handles context engine and memory management
BACKEND_URL=http://localhost:3001

# =============================================================================
# REQUIRED: AI Provider (Z.AI)
# =============================================================================

# Z.AI API Key - get from https://z.ai/
# This is required for AI chat functionality
ZAI_API_KEY=your_zai_api_key_here

# Z.AI API Base URL (usually no need to change)
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Z.AI Chat Model (default: glm-4.7)
ZAI_CHAT_MODEL=glm-4.7

# Z.AI Model for translation (default: glm-4.7)
ZAI_MODEL=glm-4.7

# Chat temperature (0-1, default: 0.7)
ZAI_CHAT_TEMPERATURE=0.7

# Max tokens per response (default: 4096)
ZAI_MAX_TOKENS=4096

# =============================================================================
# OPTIONAL: Debug Settings
# =============================================================================

# Enable debug logging for chat
DEBUG_CHAT=false

# Allowed CORS origins (comma-separated, or "*" for all)
ALLOWED_ORIGINS=*

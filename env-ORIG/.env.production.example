# ============================================================================
# VIVIM Chatbot - Production Environment (Supabase)
# ============================================================================
# Use this for PRODUCTION deployment with Supabase
# Copy to .env.production and configure for your production environment
# ============================================================================

# ============================================================================
# FRONTEND (Next.js) - Production
# ============================================================================
# Production Backend URL (update after deployment)
BACKEND_URL=https://api.vivim.live
NEXT_PUBLIC_API_URL=https://api.vivim.live

# ============================================================================
# Z.AI API - Production
# ============================================================================
ZAI_API_KEY=your-production-zai-api-key
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4.7-flash

# Translation Settings
TRANSLATE_MAX_BATCH=30
TRANSLATE_TEMPERATURE=0.1

# Chat Settings
ZAI_CHAT_MODEL=glm-4.7
ZAI_CHAT_TEMPERATURE=0.7
ZAI_MAX_TOKENS=4096
DEBUG_CHAT=false

# ============================================================================
# SUPABASE - Production
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://hrdoyqlvwipzuslaphva.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_KEY=your-production-service-key

# ============================================================================
# BACKEND (Express Server) - Production (Supabase PostgreSQL)
# ============================================================================
# Supabase PostgreSQL Connection String
# Get from Supabase Dashboard > Settings > Database
DATABASE_URL="postgresql://postgres.[project-ref]:[your-db-password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DATABASE_SSL_REQUIRED=true

# Redis (Production - e.g., Upstash, Redis Cloud)
REDIS_URL=redis://your-production-redis-url

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
TRUST_PROXY=true

# Security - GENERATE NEW SECRETS FOR PRODUCTION
SESSION_SECRET=generate-with-openssl-rand-base64-32
JWT_SECRET=generate-with-openssl-rand-base64-32
API_KEYS=sk-vivim-prod-key-generate-secure-key

# CORS - Production domains only
CORS_ORIGINS=https://vivim.live,https://www.vivim.live

# Context Engine
USE_DYNAMIC_CONTEXT=true
LIBRARIAN_ENABLED=true
ENABLE_IDLE_DETECTION=true

# Logging
LOG_LEVEL=info
DEBUG=false

# ============================================================================
# RATE LIMITING - Production
# ============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================================================
# AI PROVIDERS - Production (Optional fallbacks)
# ============================================================================
# OPENAI_API_KEY=sk-prod-...
# ANTHROPIC_API_KEY=sk-ant-prod-...
# GOOGLE_AI_API_KEY=...
